{
  "name": "event-horizon-vscode",
  "publisher": "HeytalePazguato",
  "version": "1.1.0",
  "private": true,
  "displayName": "Event Horizon",
  "description": "Real-time visual monitoring for Claude Code, OpenCode & Copilot — see agent activity, file collisions, token costs, and cooperation at a glance.",
  "license": "SEE LICENSE IN LICENSE",
  "main": "out/extension.js",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#0a0f18",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "agent-orchestration",
    "claude-code",
    "opencode",
    "copilot",
    "monitoring",
    "visualization",
    "software-architecture",
    "software-planning",
    "ai-coding",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/HeytalePazguato/event-horizon.git"
  },
  "activationEvents": [
    "onCommand:eventHorizon.open"
  ],
  "contributes": {
    "commands": [
      {
        "command": "eventHorizon.open",
        "title": "Event Horizon: Open Universe",
        "icon": "$(rocket)"
      },
      {
        "command": "eventHorizon.setupClaudeCode",
        "title": "Event Horizon: Connect Claude Code"
      },
      {
        "command": "eventHorizon.toggleView",
        "title": "Event Horizon: Toggle Operations View",
        "icon": "$(layout)"
      },
      {
        "command": "eventHorizon.focusWaitingAgent",
        "title": "Event Horizon: Focus Waiting Agent"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "eventHorizon.open",
          "group": "navigation"
        },
        {
          "command": "eventHorizon.toggleView",
          "group": "navigation",
          "when": "activeWebviewPanelId == 'eventHorizon.universe'"
        }
      ]
    },
    "keybindings": [
      {
        "command": "eventHorizon.open",
        "key": "ctrl+shift+e h",
        "mac": "cmd+shift+e h"
      },
      {
        "command": "eventHorizon.toggleView",
        "key": "ctrl+shift+e o",
        "mac": "cmd+shift+e o"
      }
    ],
    "configuration": {
      "title": "Event Horizon",
      "properties": {
        "eventHorizon.port": {
          "type": "number",
          "default": 28765,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port for the local event server that receives agent hooks. Requires extension restart.",
          "order": 1
        },
        "eventHorizon.fileLockingEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable file locking to prevent multiple agents from writing to the same file simultaneously. When enabled, agents must acquire a lock before writing — conflicting writes are blocked. Requires reinstalling hooks.",
          "order": 2
        },
        "eventHorizon.animationSpeed": {
          "type": "number",
          "default": 1.0,
          "minimum": 0.25,
          "maximum": 3.0,
          "description": "Animation speed multiplier (0.25 = slow-mo, 3.0 = fast-forward).",
          "order": 2
        },
        "eventHorizon.fontSize": {
          "type": "string",
          "default": "default",
          "enum": ["small", "default", "large"],
          "enumDescriptions": ["Smaller text (87%)", "Default text size", "Larger text for improved readability (115%)"],
          "description": "UI font size for the Event Horizon panel. Affects all text in the universe and operations views.",
          "order": 3
        },
        "eventHorizon.defaultView": {
          "type": "string",
          "default": "universe",
          "enum": ["universe", "operations"],
          "enumDescriptions": ["Cosmic planet visualization", "Full-screen dashboard with tabs"],
          "description": "Which view to show when opening Event Horizon.",
          "order": 3
        },
        "eventHorizon.planShowAllColumns": {
          "type": "boolean",
          "default": false,
          "description": "Show all Kanban columns in the Plan tab, including empty ones.",
          "order": 4
        },
        "eventHorizon.achievementsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable achievement medals and toast notifications.",
          "order": 5
        },
        "eventHorizon.agentColors.claudeCode": {
          "type": "string",
          "default": "#88aaff",
          "format": "color",
          "description": "Planet color for Claude Code agents.",
          "order": 10
        },
        "eventHorizon.agentColors.copilot": {
          "type": "string",
          "default": "#cc88ff",
          "format": "color",
          "description": "Planet color for GitHub Copilot agents.",
          "order": 11
        },
        "eventHorizon.agentColors.opencode": {
          "type": "string",
          "default": "#88ffaa",
          "format": "color",
          "description": "Planet color for OpenCode agents.",
          "order": 12
        },
        "eventHorizon.agentColors.cursor": {
          "type": "string",
          "default": "#44ddcc",
          "format": "color",
          "description": "Planet color for Cursor agents.",
          "order": 13
        },
        "eventHorizon.agentColors.unknown": {
          "type": "string",
          "default": "#aaccff",
          "format": "color",
          "description": "Planet color for unrecognized agent types.",
          "order": 14
        },
        "eventHorizon.agentSizes.claudeCode": {
          "type": "number",
          "default": 1.35,
          "minimum": 0.4,
          "maximum": 2.0,
          "description": "Planet size multiplier for Claude Code agents.",
          "order": 20
        },
        "eventHorizon.agentSizes.copilot": {
          "type": "number",
          "default": 0.72,
          "minimum": 0.4,
          "maximum": 2.0,
          "description": "Planet size multiplier for GitHub Copilot agents.",
          "order": 21
        },
        "eventHorizon.agentSizes.opencode": {
          "type": "number",
          "default": 1.0,
          "minimum": 0.4,
          "maximum": 2.0,
          "description": "Planet size multiplier for OpenCode agents.",
          "order": 22
        },
        "eventHorizon.agentSizes.cursor": {
          "type": "number",
          "default": 0.92,
          "minimum": 0.4,
          "maximum": 2.0,
          "description": "Planet size multiplier for Cursor agents.",
          "order": 23
        },
        "eventHorizon.agentSizes.unknown": {
          "type": "number",
          "default": 1.12,
          "minimum": 0.4,
          "maximum": 2.0,
          "description": "Planet size multiplier for unrecognized agent types.",
          "order": 24
        },
        "eventHorizon.spawnTerminalFocus": {
          "type": "string",
          "default": "focus-on-interaction",
          "enum": ["background", "focus", "focus-on-interaction"],
          "enumDescriptions": [
            "Keep terminal in background after spawning",
            "Focus the terminal immediately after spawning",
            "Focus the terminal when the agent needs interaction (waiting state)"
          ],
          "description": "When spawning an agent via the orchestrator, how to handle terminal focus.",
          "order": 6
        },
        "eventHorizon.roles.custom": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Unique role identifier (lowercase, hyphens allowed)" },
              "name": { "type": "string", "description": "Display name" },
              "description": { "type": "string", "description": "What this role specializes in" },
              "skills": { "type": "array", "items": { "type": "string" }, "description": "Skill names to recommend for this role" },
              "instructions": { "type": "string", "description": "Markdown instructions sent to the agent when assigned this role" }
            },
            "required": ["id", "name", "description"]
          },
          "markdownDescription": "Define custom agent roles beyond the 6 built-in ones (researcher, planner, implementer, reviewer, tester, debugger). Each role maps to skills and instructions.",
          "order": 20
        },
        "eventHorizon.roles.assignments": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "string" },
          "markdownDescription": "Map role IDs to default agent types. Example: `{ \"researcher\": \"claude-code\", \"reviewer\": \"copilot\" }`",
          "order": 21
        }
      }
    },
    "walkthroughs": [
      {
        "id": "eventHorizon.gettingStarted",
        "title": "Get Started with Event Horizon",
        "description": "Set up your AI coding agent universe in 5 steps.",
        "steps": [
          {
            "id": "openUniverse",
            "title": "Open the Universe",
            "description": "Open the Event Horizon panel from the activity bar.\n\n[Open Universe](command:eventHorizon.open)",
            "media": {
              "markdown": "assets/walkthrough/open-universe.md"
            },
            "completionEvents": [
              "onView:eventHorizon.universe"
            ]
          },
          {
            "id": "connectAgent",
            "title": "Connect an Agent",
            "description": "Install hooks for Claude Code, OpenCode, or GitHub Copilot.\n\n[Connect Claude Code](command:eventHorizon.setupClaudeCode)",
            "media": {
              "markdown": "assets/walkthrough/connect-agent.md"
            },
            "completionEvents": [
              "onCommand:eventHorizon.setupClaudeCode"
            ]
          },
          {
            "id": "exploreUniverse",
            "title": "Explore the Universe",
            "description": "Planets, ships, lightning arcs, astronauts — discover the cosmic visualization.",
            "media": {
              "markdown": "assets/walkthrough/explore-universe.md"
            }
          },
          {
            "id": "commandCenter",
            "title": "Use the Command Center",
            "description": "Select planets, view metrics, control agents, and earn achievements.",
            "media": {
              "markdown": "assets/walkthrough/command-center.md"
            }
          },
          {
            "id": "skills",
            "title": "Manage Agent Skills",
            "description": "Discover, create, organize, and browse skills from the marketplace.",
            "media": {
              "markdown": "assets/walkthrough/skills.md"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "tsc && pnpm run build:webview",
    "lint": "eslint src/ webview/",
    "build:ext": "esbuild src/extension.ts --bundle --outfile=out/extension.js --format=cjs --platform=node --external:vscode --sourcemap",
    "build:ext:prod": "esbuild src/extension.ts --bundle --outfile=out/extension.js --format=cjs --platform=node --external:vscode --minify --sourcemap=linked",
    "build:webview": "node webview/esbuild.mjs",
    "build:webview:prod": "node webview/esbuild.mjs --minify",
    "package:vsix": "pnpm run build:ext:prod && pnpm run build:webview:prod && vsce package --no-dependencies",
    "test": "vitest run",
    "dev": "tsc --watch",
    "clean": "rm -rf out webview-dist"
  },
  "dependencies": {
    "@event-horizon/connectors": "workspace:*",
    "@event-horizon/core": "workspace:*",
    "@event-horizon/renderer": "workspace:*",
    "@event-horizon/ui": "workspace:*",
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.27.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.2"
  }
}
