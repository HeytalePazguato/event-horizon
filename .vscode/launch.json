{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Event Horizon Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/vscode",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/vscode/out/**/*.js"
      ],
      "preLaunchTask": "build:event-horizon"
    }
  ]
}
